# ===== Required =====
# OpenAI-compatible API key, used for DeepSeek or another compatible model provider.
OPENAI_API_KEY=

# PostgreSQL connection string for local development.
DATABASE_URL=postgresql://ai_agent:ai_agent@localhost:5432/ai_pro_agent

# ===== Optional defaults =====
# MODEL_PROVIDER=openai-compatible
# MODEL_BASE_URL=https://api.deepseek.com
# MODEL_NAME=deepseek-v4-pro
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-pro
# EMBEDDING_MODEL=text-embedding-3-small
# PORT=3003
# NODE_ENV=development
# DEFAULT_USER_EMAIL=local@ai-pro-agent.dev

# ===== Optional integrations =====
# GITHUB_TOKEN=
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
# CLIENT_DIST_DIR=
