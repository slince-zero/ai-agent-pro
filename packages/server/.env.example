# ===== 必填 =====
# AI 模型 API Key。兼容 OpenAI 格式，用于调用 DeepSeek 等模型
OPENAI_API_KEY=

# PostgreSQL 数据库连接字符串。Docker 部署时主机名改为 postgres（服务名）
DATABASE_URL=postgresql://ai_agent:ai_agent@localhost:5432/ai_pro_agent

# ===== 可选（有默认值） =====
# 模型供应商：openai-compatible | anthropic
# 当前已实现 openai-compatible；anthropic 为预留适配入口
# MODEL_PROVIDER=openai-compatible

# OpenAI-compatible API 基础地址；未设置时回退到 DEEPSEEK_BASE_URL
# MODEL_BASE_URL=https://api.deepseek.com

# 使用的模型名称；未设置时回退到 DEEPSEEK_MODEL
# MODEL_NAME=deepseek-v4-pro

# 兼容旧配置：DeepSeek API 基础地址
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# 兼容旧配置：DeepSeek 模型名称
# DEEPSEEK_MODEL=deepseek-v4-pro

# 服务端口号
# PORT=3003

# 运行环境：development | production | test
# NODE_ENV=development

# 反向代理信任边界。生产环境必填；单层代理填 1，也可填写明确 IP/子网并用逗号分隔
# 禁止 true、*、0.0.0.0/0、::/0 等全局信任配置
# TRUST_PROXY=1

# API 请求与滥用控制。默认 64 KiB body、4 KiB URL、15 分钟窗口
# API_MAX_BODY_BYTES=65536
# API_MAX_URL_CHARS=4096
# API_RATE_LIMIT_WINDOW_MS=900000
# API_RATE_LIMIT_MAX=300
# AUTH_RATE_LIMIT_MAX=60
# RUN_RATE_LIMIT_MAX=10
# RUN_CONCURRENCY_MAX=2

# 默认用户邮箱（本地开发用）
# DEFAULT_USER_EMAIL=local@ai-pro-agent.dev

# db:seed 可选登录密码。仅显式设置时创建 credential account，至少 8 字符
# DEFAULT_USER_PASSWORD=

# Docker 代码沙箱。默认关闭；启用前先阅读 docs/CODE_SANDBOX.md
# CODE_SANDBOX_ENABLED=false
# CODE_SANDBOX_DOCKER_BINARY=docker
# CODE_SANDBOX_JAVASCRIPT_IMAGE=node:22-alpine
# CODE_SANDBOX_PYTHON_IMAGE=python:3.13-alpine

# ===== 可选（无默认值） =====
# Better Auth 服务端密钥。生产环境必填，至少 32 字符；可用 openssl rand -base64 32 生成
# BETTER_AUTH_SECRET=

# Better Auth 对外访问的应用根 URL。生产环境必填，不包含 /api/auth
# BETTER_AUTH_URL=https://agent.example.com

# 用户浏览器访问的前端根 URL。前后端同域时可与 BETTER_AUTH_URL 相同
# AUTH_APP_URL=https://agent.example.com

# 允许携带认证 Cookie 调用 API 的额外前端 Origin，多个值用逗号分隔
# AUTH_TRUSTED_ORIGINS=https://app.example.com

# 事务邮件。开发环境默认 console，会在服务端日志中输出邮件内容和操作链接
# 生产环境必须使用 resend，并配置已验证域名的发件地址和 API Key
# AUTH_EMAIL_PROVIDER=console
# AUTH_EMAIL_FROM=AI Engineering Agent <auth@example.com>
# RESEND_API_KEY=

# GitHub Personal Access Token。用于调用 GitHub API，避免未认证时触发限流
# GITHUB_TOKEN=

# 外部 MCP server 配置。支持 Claude Desktop 风格 {"mcpServers":{...}} 或数组。
# 只在可信本地开发/部署环境中配置会启动进程的 command。
# MCP_SERVERS_JSON={"mcpServers":{"filesystem":{"command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/tmp"]}}}

# 生产环境前端静态文件目录
# CLIENT_DIST_DIR=
