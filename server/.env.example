# AI 模型 API Key（必填）。兼容 OpenAI 格式，用于调用 DeepSeek 等模型
OPENAI_API_KEY=
# DeepSeek API 基础地址，默认使用官方 API
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 使用的模型名称，默认 deepseek-v4-pro
DEEPSEEK_MODEL=deepseek-v4-pro
# GitHub Personal Access Token（可选）。用于调用 GitHub API，避免未认证时触发限流
GITHUB_TOKEN=
# PostgreSQL 数据库连接字符串。Docker 部署时主机名改为 postgres（服务名）
DATABASE_URL=postgresql://ai_agent:ai_agent@localhost:5432/ai_pro_agent
