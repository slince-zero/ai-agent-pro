generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]
}

model Session {
  id        String        @id @default(cuid())
  userId    String
  title     String
  status    SessionStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  agentRuns AgentRun[]

  @@index([userId, updatedAt])
}

model Message {
  id        String      @id @default(cuid())
  sessionId String
  role      MessageRole
  content   String
  metadata  Json?
  createdAt DateTime    @default(now())

  session       Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userRuns      AgentRun[] @relation("RunUserMessage")
  assistantRuns AgentRun[] @relation("RunAssistantMessage")

  @@index([sessionId, createdAt])
}

model AgentRun {
  id                 String    @id @default(cuid())
  sessionId          String
  userMessageId      String?
  assistantMessageId String?
  status             RunStatus @default(RUNNING)
  model              String
  error              String?
  startedAt          DateTime  @default(now())
  finishedAt         DateTime?

  session          Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userMessage      Message?   @relation("RunUserMessage", fields: [userMessageId], references: [id])
  assistantMessage Message?   @relation("RunAssistantMessage", fields: [assistantMessageId], references: [id])
  toolCalls        ToolCall[]

  @@index([sessionId, startedAt])
  @@index([status])
}

model ToolCall {
  id         String         @id @default(cuid())
  runId      String
  toolCallId String?
  name       String
  arguments  Json?
  result     String?
  status     ToolCallStatus @default(RUNNING)
  error      String?
  startedAt  DateTime       @default(now())
  finishedAt DateTime?

  run AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([name])
  @@index([status])
}

enum SessionStatus {
  ACTIVE   @map("active")
  ARCHIVED @map("archived")
}

enum MessageRole {
  USER      @map("user")
  ASSISTANT @map("assistant")
  SYSTEM    @map("system")
  TOOL      @map("tool")
}

enum RunStatus {
  RUNNING   @map("running")
  COMPLETED @map("completed")
  FAILED    @map("failed")
  CANCELED  @map("canceled")
}

enum ToolCallStatus {
  RUNNING   @map("running")
  COMPLETED @map("completed")
  FAILED    @map("failed")
}
