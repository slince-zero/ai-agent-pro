{
  "name": "ai-agent-pro",
  "private": true,
  "scripts": {
    "dev": "scripts/dev-local.sh",
    "dev:app": "pnpm --filter server --filter client --parallel dev",
    "dev:setup": "scripts/dev-setup.sh",
    "db:up": "docker compose up -d postgres",
    "db:generate": "pnpm --filter server run generate",
    "db:migrate": "pnpm --filter server run migrate:deploy",
    "build": "pnpm -r build",
    "start": "pnpm --filter server start",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "fix": "pnpm fmt && pnpm lint:fix",
    "lint:ci": "pnpm lint && pnpm fmt:check",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "eval": "pnpm --filter server exec tsx src/evals/cli.ts",
    "eval:smoke": "pnpm eval -- --suite smoke --provider mock"
  },
  "devDependencies": {
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0"
  },
  "packageManager": "pnpm@11.5.2"
}
